[32m+[m[32m    # --------------------- Normalización fuerte de hora ---------------------[m
[32m+[m[32m    def _hora_a_hhmmss(self, hora, index: int, campo: str) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Normaliza Entrada/Salida a 'HH:MM:SS' para que MySQL TIME y triggers calculen en INSERT.[m
[32m+[m[32m        """[m
[32m+[m[32m        try:[m
[32m+[m[32m            if hora is None or (isinstance(hora, float) and pd.isna(hora)):[m
[32m+[m[32m                print(f"⚠️ Hora vacía detectada en fila {index + 1} ({campo}). Se asigna '00:00:00'")[m
[32m+[m[32m                return "00:00:00"[m
[32m+[m
[32m+[m[32m            # pandas Timestamp / datetime[m
[32m+[m[32m            if isinstance(hora, datetime):[m
[32m+[m[32m                return hora.strftime("%H:%M:%S")[m
[32m+[m
[32m+[m[32m            # time[m
[32m+[m[32m            if isinstance(hora, time):[m
[32m+[m[32m                return hora.strftime("%H:%M:%S")[m
[32m+[m
[32m+[m[32m            # timedelta (MUY común en Excel)[m
[32m+[m[32m            if isinstance(hora, timedelta):[m
[32m+[m[32m                total = int(hora.total_seconds())[m
[32m+[m[32m                hh = (total // 3600) % 24[m
[32m+[m[32m                mm = (total % 3600) // 60[m
[32m+[m[32m                ss = total % 60[m
[32m+[m[32m                return f"{hh:02}:{mm:02}:{ss:02}"[m
[32m+[m
[32m+[m[32m            s = str(hora).strip()[m
[32m+[m[32m            if not s or s.lower() in ["nan", "none"]:[m
[32m+[m[32m                print(f"⚠️ Hora vacía detectada en fila {index + 1} ({campo}). Se asigna '00:00:00'")[m
[32m+[m[32m                return "00:00:00"[m
[32m+[m
[32m+[m[32m            # Si viene como "0 days 06:24:00"[m
[32m+[m[32m            if "day" in s and ":" in s:[m
[32m+[m[32m                # tomar la parte final después del espacio[m
[32m+[m[32m                parts = s.split()[m
[32m+[m[32m                for p in reversed(parts):[m
[32m+[m[32m                    if ":" in p:[m
[32m+[m[32m                        s = p[m
[32m+[m[32m                        break[m
[32m+[m
[32m+[m[32m            # Decimal fracción de día (0.25=06:00)[m
[32m+[m[32m            try:[m
[32m+[m[32m                if s.replace(".", "", 1).isdigit():[m
[32m+[m[32m                    f = float(s)[m
[32m+[m[32m                    if 0 <= f < 1:[m
[32m+[m[32m                        total_seconds = int(round(f * 24 * 3600))[m
[32m+[m[32m                        hh = total_seconds // 3600[m
[32m+[m[32m                        mm = (total_seconds % 3600) // 60[m
[32m+[m[32m                        ss = total_seconds % 60[m
[32m+[m[32m                        return f"{hh:02}:{mm:02}:{ss:02}"[m
[32m+[m[32m            except Exception:[m
[32m+[m[32m                pass[m
[32m+[m
[32m+[m[32m            # HH:MM o HH:MM:SS[m
[32m+[m[32m            parts = s.split(":")[m
[32m+[m[32m            if len(parts) == 2:[m
[32m+[m[32m                hh = int(parts[0])[m
[32m+[m[32m                mm = int(parts[1])[m
[32m+[m[32m                return f"{hh:02}:{mm:02}:00"[m
[32m+[m[32m            if len(parts) >= 3:[m
[32m+[m[32m                hh = int(parts[0])[m
[32m+[m[32m                mm = int(parts[1])[m
[32m+[m[32m                ss = int(parts[2])[m
[32m+[m[32m                return f"{hh:02}:{mm:02}:{ss:02}"[m
[32m+[m
[32m+[m[32m            # Si no se pudo, devolver raw (último recurso)[m
[32m+[m[32m            return s[m
[32m+[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return "00:00:00"[m
[32m+[m
