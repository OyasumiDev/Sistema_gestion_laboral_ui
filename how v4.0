[32m+[m[32m                width=self.actions_width,[m
[32m+[m[32m                alignment=ft.alignment.center,[m
[32m+[m[32m            )[m
[32m+[m[32m        )[m
[32m+[m
[32m+[m
[32m+[m[32m        return ft.DataColumn([m
[32m+[m[32m            label=ft.Container([m
[32m+[m[32m                content=head,[m
[32m+[m[32m                width=self.actions_width,[m
[32m+[m[32m                alignment=ft.alignment.center,[m
[32m+[m[32m            )[m
[32m+[m[32m        )[m
[32m+[m
