[32m+[m[32m    # ------------------ callbacks blindados ------------------[m
[32m+[m[32m    def _call_actualizar(self, grupo: Optional[str], campo: str, valor: Any):[m
[32m+[m[32m        cb = self.actualizar_callback[m
[32m+[m[32m        if not callable(cb):[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        # 1) kwargs[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(grupo=grupo, campo=campo, valor=valor)[m
[32m+[m[32m            return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m        # 2) 3 args[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(grupo, campo, valor)[m
[32m+[m[32m            return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m        # 3) 2 args[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(campo, valor)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m    def _call_recalcular(self, grupo: Optional[str] = None, registro: Optional[dict] = None):[m
[32m+[m[32m        cb = self.recalcular_callback[m
[32m+[m[32m        if not callable(cb):[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(grupo=grupo, registro=registro)[m
[32m+[m[32m            return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(grupo, registro)[m
[32m+[m[32m            return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb(registro)[m
[32m+[m[32m            return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            cb()[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m    # ------------------ normalización ------------------[m
[32m+[m[32m    def _default_descanso(self, registro: dict) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Default del módulo: MD.[m
[32m+[m[32m        - None / "" / "NULL" -> MD[m
[32m+[m[32m        - "SN"/"MD"/"CMP" -> respeta[m
[32m+[m[32m        - 0/1/2 -> etiqueta[m
[32m+[m[32m        """[m
[32m+[m[32m        v = registro.get("descanso", None)[m
[32m+[m[32m        if v is None:[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        s = str(v).strip().upper()[m
[32m+[m[32m        if s in ("", "NONE", "NULL"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        if s in ("SN", "MD", "CMP"):[m
[32m+[m[32m            return s[m
[32m+[m[32m        if s in ("0", "1", "2"):[m
[32m+[m[32m            return {"0": "SN", "1": "MD", "2": "CMP"}[s][m
[32m+[m[32m        return "MD"[m
[32m+[m
[32m+[m[32m    def _solo_horas(self, v: Any) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        En la columna de horas SOLO mostrar HH:MM[:SS].[m
[32m+[m[32m        Si viene 'MD 00:00:00' o 'SN 09:59:00', lo limpia.[m
[32m+[m[32m        """[m
[32m+[m[32m        s = str(v or "").strip()[m
[32m+[m[32m        if not s:[m
[32m+[m[32m            return ""[m
[32m+[m[32m        parts = s.split()[m
[32m+[m[32m        if len(parts) >= 2 and parts[0].upper() in ("SN", "MD", "CMP"):[m
[32m+[m[32m            return parts[1].strip()[m
[32m+[m[32m        return s[m
[32m+[m
[32m+[m[32m    def _estado_color(self, estado: str) -> str:[m
[32m+[m[32m        e = (estado or "").strip().upper()[m
[32m+[m[32m        if e == "INCOMPLETO" or e.startswith("HORAS"):[m
[32m+[m[32m            return ft.colors.RED[m
[32m+[m[32m        if e == "COMPLETO":[m
[32m+[m[32m            return ft.colors.GREEN[m
[32m+[m[32m        if e == "DUPLICADO":[m
[32m+[m[32m            return ft.colors.RED_600[m
[32m+[m[32m        if e == "PENDIENTE":[m
[32m+[m[32m            return ft.colors.GREY[m
[32m+[m[32m        return ft.colors.GREY[m
[32m+[m
[32m+[m[32m    def _set_field_error(self, tf: ft.TextField, msg: str | None = None):[m
[32m+[m[32m        tf.color = ft.colors.RED_400[m
[32m+[m[32m        tf.tooltip = msg or "Dato inválido"[m
[32m+[m
[32m+[m[32m    def _clear_field_error(self, tf: ft.TextField):[m
[32m+[m[32m        tf.color = None[m
[32m+[m[32m        tf.tooltip = None[m
[32m+[m
[32m+[m[32m    def _set_border_error(self, tf: ft.TextField, msg: str | None = None):[m
[32m+[m[32m        tf.border_color = ft.colors.RED[m
[32m+[m[32m        tf.tooltip = msg or "Dato inválido"[m
[32m+[m
[32m+[m[32m    def _clear_border_error(self, tf: ft.TextField):[m
[32m+[m[32m        tf.border_color = None[m
[32m+[m[32m        tf.tooltip = None[m
[32m+[m
[32m+[m[32m    def _is_hora_completa(self, v: str) -> bool:[m
[32m+[m[32m        if not v:[m
[32m+[m[32m            return False[m
[32m+[m[32m        s = v.strip()[m
[32m+[m[32m        m = re.fullmatch(r"(\d{1,2}):(\d{2})(?::(\d{2}))?$", s)[m
[32m+[m[32m        if not m:[m
[32m+[m[32m            return False[m
[32m+[m[32m        try:[m
[32m+[m[32m            h = int(m.group(1))[m
[32m+[m[32m            mi = int(m.group(2))[m
[32m+[m[32m            se = int(m.group(3)) if m.group(3) else 0[m
[32m+[m[32m            return 0 <= h <= 23 and 0 <= mi <= 59 and 0 <= se <= 59[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return False[m
[32m+[m
[32m+[m[32m    def _norm_fecha(self, fecha: str) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Normaliza fecha a 'YYYY-MM-DD' si es posible.[m
[32m+[m[32m        Soporta 'DD/MM/YYYY' y 'YYYY-MM-DD'.[m
[32m+[m[32m        """[m
[32m+[m[32m        s = (fecha or "").strip()[m
[32m+[m[32m        if not s:[m
[32m+[m[32m            return ""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if "/" in s:[m
[32m+[m[32m                dt = self.calculo_helper.parse_fecha_ddmmyyyy(s)[m
[32m+[m[32m                return dt.strftime("%Y-%m-%d")[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m[32m        return s[m
[32m+[m
[32m+[m[32m    # ------------------ DB snapshot merge ------------------[m
[32m+[m[32m    def _merge_snapshot(self, registro: dict, snapshot: dict) -> None:[m
[32m+[m[32m        """[m
[32m+[m[32m        Mezcla snapshot de DB dentro de registro, normalizando descanso a etiqueta.[m
[32m+[m[32m        """[m
[32m+[m[32m        if not isinstance(snapshot, dict):[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        # Merge crudo[m
[32m+[m[32m        for k, v in snapshot.items():[m
[32m+[m[32m            registro[k] = v[m
[32m+[m
[32m+[m[32m        # Normaliza descanso a SN/MD/CMP para la UI[m
[32m+[m[32m        registro["descanso"] = self._default_descanso(registro)[m
[32m+[m
[32m+[m[32m        # Normaliza horas mostrables[m
[32m+[m[32m        if "tiempo_trabajo" in registro:[m
[32m+[m[32m            registro["tiempo_trabajo"] = self._solo_horas(registro.get("tiempo_trabajo"))[m
[32m+[m[32m        if "tiempo_trabajo_con_descanso" in registro:[m
[32m+[m[32m            registro["tiempo_trabajo_con_descanso"] = self._solo_horas(registro.get("tiempo_trabajo_con_descanso"))[m
[32m+[m
[32m+[m[32m        # Normaliza estado[m
[32m+[m[32m        if "estado" in registro and registro["estado"] is not None:[m
[32m+[m[32m            registro["estado"] = str(registro["estado"]).strip().upper()[m
[32m+[m
[32m+[m[32m    def _extract_snapshot(self, ret: Any) -> Optional[dict]:[m
[32m+[m[32m        """[m
[32m+[m[32m        Acepta retornos comunes:[m
[32m+[m[32m        - dict fila directa[m
[32m+[m[32m        - {"data": {...}}[m
[32m+[m[32m        - {"status":"success","data": {...}}[m
[32m+[m[32m        """[m
[32m+[m[32m        if isinstance(ret, dict):[m
[32m+[m[32m            if "data" in ret and isinstance(ret["data"], dict):[m
[32m+[m[32m                return ret["data"][m
[32m+[m[32m            # Si parece fila[m
[32m+[m[32m            if any(k in ret for k in ("numero_nomina", "fecha", "hora_entrada", "hora_salida", "tiempo_trabajo", "descanso")):[m
[32m+[m[32m                return ret[m
[32m+[m[32m        return None[m
[32m+[m
[32m+[m[32m    def _call_commit_descanso_and_refresh([m
         self,[m
[31m-        grupo_importacion: str,[m
[31m-        registro: Dict,[m
[31m-        on_save: Callable,[m
[31m-        on_cancel: Callable,[m
[31m-        registros_del_grupo: list[m
[31m-    ) -> ft.DataRow:[m
[31m-        if not registro.get("descanso"):[m
[31m-            registro["descanso"] = "MD"[m
[31m-        if not registro.get("estado"):[m
[31m-            registro["estado"] = "PENDIENTE"[m
[32m+[m[32m        grupo: Optional[str],[m
[32m+[m[32m        registro: dict,[m
[32m+[m[32m        tiempo_field: Optional[ft.TextField],[m
[32m+[m[32m        estado_text: Optional[ft.Text],[m
[32m+[m[32m    ):[m
[32m+[m[32m        """[m
[32m+[m[32m        Llama commit_descanso_callback y, si regresa snapshot, lo aplica y repinta.[m
[32m+[m[32m        """[m
[32m+[m[32m        cb = self.commit_descanso_callback[m
[32m+[m[32m        if not callable(cb):[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        # payload minimal (por si tu container prefiere eso)[m
[32m+[m[32m        payload = {[m
[32m+[m[32m            "numero_nomina": registro.get("numero_nomina"),[m
[32m+[m[32m            "fecha": registro.get("fecha"),[m
[32m+[m[32m            "descanso": registro.get("descanso"),[m
[32m+[m[32m            "grupo_importacion": registro.get("grupo_importacion"),[m
[32m+[m[32m        }[m
[32m+[m
[32m+[m[32m        ret = None[m
[32m+[m
[32m+[m[32m        # 1) intento clásico: cb(registro)[m
[32m+[m[32m        try:[m
[32m+[m[32m            ret = cb(registro)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            # 2) kwargs[m
[32m+[m[32m            try:[m
[32m+[m[32m                ret = cb(grupo=grupo, registro=registro, payload=payload)[m
[32m+[m[32m            except Exception:[m
[32m+[m[32m                # 3) payload[m
[32m+[m[32m                try:[m
[32m+[m[32m                    ret = cb(payload)[m
[32m+[m[32m                except Exception:[m
[32m+[m[32m                    ret = None[m
[32m+[m
[32m+[m[32m        snap = self._extract_snapshot(ret)[m
[32m+[m[32m        if not snap:[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        # aplica snapshot DB[m
[32m+[m[32m        self._merge_snapshot(registro, snap)[m
[32m+[m
[32m+[m[32m        # repinta descanso/estado/tiempo desde DB[m
[32m+[m[32m        if tiempo_field is not None:[m
[32m+[m[32m            # ✅ la columna debe mostrar NETO[m
[32m+[m[32m            tiempo_field.value = self._solo_horas(registro.get("tiempo_trabajo") or "00:00:00")[m
[32m+[m
[32m+[m[32m        if estado_text is not None:[m
[32m+[m[32m            est = (registro.get("estado") or "PENDIENTE").strip().upper()[m
[32m+[m[32m            if estado_text.value != "DUPLICADO":[m
[32m+[m[32m                estado_text.value = est[m
[32m+[m[32m                estado_text.color = self._estado_color(est)[m
[32m+[m
[32m+[m[32m        self._soft_update(force=True)[m
[32m+[m
[32m+[m[32m    def _apply_recalc_result(self, registro: dict, tiempo_field: ft.TextField, estado_text: ft.Text, res: dict):[m
[32m+[m[32m        """[m
[32m+[m[32m        Aplica resultado de recalculo.[m
[32m+[m[32m        ✅ IMPORTANTE: el campo mostrado en la columna debe ser NETO (tiempo_trabajo),[m
[32m+[m[32m           porque eso es lo que cambia con descanso.[m
[32m+[m[32m        """[m
[32m+[m[32m        manual_activo = bool(registro.get("__tiempo_manual"))[m
[32m+[m[32m        if not manual_activo:[m
[32m+[m[32m            neto = self._solo_horas(res.get("tiempo_trabajo", "00:00:00"))[m
[32m+[m[32m            bruto = self._solo_horas(res.get("tiempo_trabajo_con_descanso", "00:00:00"))[m
[32m+[m
[32m+[m[32m            # ✅ Mostrar NETO en el TextField/columna[m
[32m+[m[32m            tiempo_field.value = neto[m
[32m+[m
[32m+[m[32m            # Guardamos ambos en registro por si luego quieres mostrar ambos[m
[32m+[m[32m            registro["tiempo_trabajo"] = neto[m
[32m+[m[32m            registro["tiempo_trabajo_con_descanso"] = bruto[m
[32m+[m
[32m+[m[32m        nuevo_estado = "COMPLETO" if res.get("estado") == "ok" else "INCOMPLETO"[m
[32m+[m[32m        registro["estado"] = nuevo_estado[m
[32m+[m[32m        if estado_text.value != "DUPLICADO":[m
[32m+[m[32m            estado_text.value = nuevo_estado[m
[32m+[m[32m            estado_text.color = self._estado_color(nuevo_estado)[m
[32m+[m
[32m+[m[32m    # ------------------ FILA VISTA ------------------[m
[32m+[m[32m    def build_fila_vista(self, registro: dict, on_edit: Callable, on_delete: Callable = None) -> ft.DataRow:[m
[32m+[m[32m        numero_nomina = registro.get("numero_nomina", "")[m
[32m+[m[32m        fecha = registro.get("fecha", "")[m
[32m+[m
[32m+[m[32m        descanso = self._default_descanso(registro)[m
[32m+[m[32m        registro["descanso"] = descanso[m
[32m+[m[32m        descanso_texto = f"{descanso}: {self.calculo_helper.obtener_minutos_descanso(descanso)} min"[m
[32m+[m
[32m+[m[32m        # ✅ Horas trabajadas (NETO) primero. Si no hay, usa bruto. Si no hay, recalcula.[m
[32m+[m[32m        tiempo_mostrar = self._solo_horas(str(registro.get("tiempo_trabajo") or "").strip())[m
[32m+[m[32m        if not tiempo_mostrar:[m
[32m+[m[32m            tiempo_mostrar = self._solo_horas(str(registro.get("tiempo_trabajo_con_descanso") or "").strip())[m
[32m+[m
[32m+[m[32m        if not tiempo_mostrar:[m
[32m+[m[32m            res = self.calculo_helper.recalcular_con_estado([m
[32m+[m[32m                self.calculo_helper.sanitizar_hora(registro.get("hora_entrada", "")),[m
[32m+[m[32m                self.calculo_helper.sanitizar_hora(registro.get("hora_salida", "")),[m
[32m+[m[32m                descanso,[m
[32m+[m[32m            )[m
[32m+[m[32m            tiempo_mostrar = self._solo_horas(res.get("tiempo_trabajo", "00:00:00"))[m
[32m+[m
[32m+[m[32m        estado_val = (registro.get("estado") or "").strip().upper() or "PENDIENTE"[m
[32m+[m[32m        estado_text = ft.Text([m
[32m+[m[32m            estado_val,[m
[32m+[m[32m            text_align=ft.TextAlign.CENTER,[m
[32m+[m[32m            color=self._estado_color(estado_val),[m
[32m+[m[32m            no_wrap=True,[m
[32m+[m[32m            max_lines=1,[m
[32m+[m[32m        )[m
[32m+[m[32m        tiempo_text = ft.Text(str(tiempo_mostrar))[m
[32m+[m[32m        # referencias para refresco puntual sin reconstruir filas[m
[32m+[m[32m        registro["__tiempo_text"] = tiempo_text[m
[32m+[m[32m        registro["__estado_text"] = estado_text[m
[32m+[m
[32m+[m[32m        acciones = [[m
[32m+[m[32m            ft.IconButton(icon=ft.icons.EDIT, tooltip="Editar", on_click=lambda e: on_edit(numero_nomina, fecha))[m
[32m+[m[32m        ][m
[32m+[m[32m        if on_delete:[m
[32m+[m[32m            acciones.append([m
[32m+[m[32m                ft.IconButton([m
[32m+[m[32m                    icon=ft.icons.DELETE_OUTLINE,[m
[32m+[m[32m                    tooltip="Eliminar",[m
[32m+[m[32m                    icon_color=ft.colors.RED_600,[m
[32m+[m[32m                    on_click=lambda e: on_delete(registro),[m
[32m+[m[32m                )[m
[32m+[m[32m            )[m
[32m+[m
[32m+[m[32m        return ft.DataRow([m
[32m+[m[32m            cells=[[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Text(str(numero_nomina)), self._W["numero_nomina"])),[m
[32m+[m[32m                ft.DataCell([m
[32m+[m[32m                    self._wrap_cell([m
[32m+[m[32m                        ft.Text([m
[32m+[m[32m                            registro.get("nombre_completo", ""),[m
[32m+[m[32m                            overflow=ft.TextOverflow.ELLIPSIS,[m
[32m+[m[32m                            max_lines=1,[m
[32m+[m[32m                            text_align=ft.TextAlign.LEFT,[m
[32m+[m[32m                        ),[m
[32m+[m[32m                        self._W["nombre_completo"],[m
[32m+[m[32m                        align_center=False,[m
[32m+[m[32m                    )[m
[32m+[m[32m                ),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Text(str(fecha)), self._W["fecha"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Text(str(registro.get("hora_entrada", ""))), self._W["hora_entrada"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Text(str(registro.get("hora_salida", ""))), self._W["hora_salida"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Text(descanso_texto), self._W["descanso"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(tiempo_text, self._W["tiempo_trabajo"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(estado_text, self._W["estado"])),[m
[32m+[m[32m                ft.DataCell(self._wrap_cell(ft.Row(acciones, spacing=5), self._W["acciones"])),[m
[32m+[m[32m            ][m
[32m+[m[32m        )[m
