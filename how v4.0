[32m+[m[32m    def _on_change_tiempo_manual(self, grupo, registro, tiempo_field):[m
[32m+[m[32m        valor = str(tiempo_field.value or "").strip()[m
[32m+[m[32m        registro["tiempo_trabajo_manual"] = valor[m
[32m+[m[32m        registro["__tiempo_manual"] = bool(valor)[m
[32m+[m[32m        tiempo_field.border_color = None[m
[32m+[m[32m        self._call_actualizar(grupo, "tiempo_trabajo_manual", valor)[m
[32m+[m
[32m+[m[32m        if not valor:[m
[32m+[m[32m            registro["__tiempo_manual"] = False[m
[32m+[m[32m            registro.pop("tiempo_trabajo_manual", None)[m
[32m+[m[32m            self._soft_update()[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            if ":" in valor:[m
[32m+[m[32m                try:[m
[32m+[m[32m                    datetime.strptime(valor, "%H:%M:%S")[m
[32m+[m[32m                except ValueError:[m
[32m+[m[32m                    datetime.strptime(valor, "%H:%M")[m
[32m+[m[32m            else:[m
[32m+[m[32m                float(valor)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            tiempo_field.border_color = ft.colors.RED[m
[32m+[m[32m            tiempo_field.tooltip = "Formato inválido. Usa HH:MM, HH:MM:SS o decimal."[m
[32m+[m[32m            self._soft_update()[m
[32m+[m[32m            return[m
[32m+[m
[32m+[m[32m        tiempo_field.tooltip = None[m
[32m+[m[32m        # manual override pisa ambos (como “valor mostrado”), pero NO afecta DB si no guardas[m
[32m+[m[32m        registro["tiempo_trabajo"] = valor[m
[32m+[m[32m        registro["tiempo_trabajo_con_descanso"] = valor[m
[32m+[m[32m        self._call_recalcular(grupo=grupo, registro=registro)[m
         self._soft_update()[m
 [m
     def _crear_botones_descanso(self, grupo, registro, tiempo_field, estado_text, entrada_field=None, salida_field=None):[m
[32m+[m[32m        """[m
[32m+[m[32m        Botones exclusivos SN / MD / CMP.[m
[32m+[m[32m        ✅ al recalcular, 'tiempo_field' se pinta con NETO (tiempo_trabajo).[m
[32m+[m[32m        ✅ autosave: llama commit_descanso_callback y aplica snapshot DB si regresa uno.[m
[32m+[m[32m        """[m
