[32m+[m[32m    # --------------------- Helpers: Fecha / Hora / Decimal ---------------------[m
[32m+[m[32m    def _parse_fecha_any(self, v) -> date | None:[m
[32m+[m[32m        """Acepta date/datetime/'DD/MM/YYYY'/'YYYY-MM-DD' y devuelve date."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if v is None:[m
[32m+[m[32m                return None[m
[32m+[m[32m            if isinstance(v, datetime):[m
[32m+[m[32m                return v.date()[m
[32m+[m[32m            if isinstance(v, date):[m
[32m+[m[32m                return v[m
[32m+[m[32m            s = str(v).strip()[m
[32m+[m[32m            if not s:[m
[32m+[m[32m                return None[m
[32m+[m[32m            if "/" in s:[m
[32m+[m[32m                return datetime.strptime(s, "%d/%m/%Y").date()[m
[32m+[m[32m            return datetime.strptime(s, "%Y-%m-%d").date()[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m    def _fecha_to_display(self, v) -> str:[m
[32m+[m[32m        d = self._parse_fecha_any(v)[m
[32m+[m[32m        return d.strftime("%d/%m/%Y") if d else (str(v) if v is not None else "")[m
[32m+[m
[32m+[m[32m    def _fecha_to_iso(self, v) -> str:[m
[32m+[m[32m        d = self._parse_fecha_any(v)[m
[32m+[m[32m        return d.strftime("%Y-%m-%d") if d else (str(v) if v is not None else "")[m
[32m+[m
[32m+[m[32m    def _decimal_horas_a_hhmm(self, v) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Convierte 7.5 -> '07:30'[m
[32m+[m[32m        Si viene 'HH:MM'/'HH:MM:SS' lo regresa normalizado a HH:MM.[m
[32m+[m[32m        """[m
[32m+[m[32m        if v is None:[m
[32m+[m[32m            return ""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if isinstance(v, (int, float, Decimal)):[m
[32m+[m[32m                total_min = int(round(float(v) * 60))[m
[32m+[m[32m                hh = total_min // 60[m
[32m+[m[32m                mm = total_min % 60[m
[32m+[m[32m                return f"{hh:02}:{mm:02}"[m
[32m+[m[32m            s = str(v).strip()[m
[32m+[m[32m            if not s:[m
[32m+[m[32m                return ""[m
[32m+[m[32m            if ":" in s:[m
[32m+[m[32m                parts = s.split(":")[m
[32m+[m[32m                if len(parts) >= 2:[m
[32m+[m[32m                    return f"{int(parts[0]):02}:{int(parts[1]):02}"[m
[32m+[m[32m                return s[m
[32m+[m[32m            f = float(s)[m
[32m+[m[32m            total_min = int(round(f * 60))[m
[32m+[m[32m            hh = total_min // 60[m
[32m+[m[32m            mm = total_min % 60[m
[32m+[m[32m            return f"{hh:02}:{mm:02}"[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return str(v)[m
[32m+[m
[32m+[m[32m    def _normalizar_hora_display(self, v) -> str:[m
[32m+[m[32m        """TIME puede venir como timedelta/time/str. Regresa 'HH:MM' para UI."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if v is None:[m
[32m+[m[32m                return ""[m
[32m+[m[32m            if isinstance(v, timedelta):[m
[32m+[m[32m                t = (datetime.min + v).time()[m
[32m+[m[32m                return t.strftime("%H:%M")[m
[32m+[m[32m            if hasattr(v, "strftime"):[m
[32m+[m[32m                return v.strftime("%H:%M")[m
[32m+[m[32m            s = str(v).strip()[m
[32m+[m[32m            if not s:[m
[32m+[m[32m                return ""[m
[32m+[m[32m            if s.count(":") >= 1:[m
[32m+[m[32m                parts = s.split(":")[m
[32m+[m[32m                return f"{int(parts[0]):02}:{int(parts[1]):02}"[m
[32m+[m[32m            return s[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return str(v) if v is not None else ""[m
[32m+[m
[32m+[m[32m    # --------------------- DESCANSO: normalizar / mapear ---------------------[m
[32m+[m[32m    def _normalizar_descanso(self, v) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Acepta:[m
[32m+[m[32m        - None, "", "NULL" -> MD[m
[32m+[m[32m        - 0/SN -> SN[m
[32m+[m[32m        - 1/MD -> MD[m
[32m+[m[32m        - 2/CMP -> CMP[m
[32m+[m[32m        """[m
[32m+[m[32m        if v is None:[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        s = str(v).strip().upper()[m
[32m+[m[32m        if s in ("", "NONE", "NULL"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        if s in ("0", "SN", "SIN"):[m
[32m+[m[32m            return "SN"[m
[32m+[m[32m        if s in ("1", "MD", "MEDIO"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        if s in ("2", "CMP", "COMIDA", "COMPLETO"):[m
[32m+[m[32m            return "CMP"[m
[32m+[m[32m        if s not in ("SN", "MD", "CMP"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        return s[m
[32m+[m
[32m+[m[32m    def _descanso_to_int(self, descanso: str) -> int:[m
[32m+[m[32m        s = self._normalizar_descanso(descanso)[m
[32m+[m[32m        return {"SN": 0, "MD": 1, "CMP": 2}.get(s, 1)[m
[32m+[m
[32m+[m[32m    def _wrap_descanso_cell_with_label(self, cell_content: ft.Control, descanso: str) -> ft.Control:[m
[32m+[m[32m        tag = ft.Container([m
[32m+[m[32m            padding=ft.padding.symmetric(horizontal=8, vertical=4),[m
[32m+[m[32m            border_radius=8,[m
[32m+[m[32m            bgcolor=ft.colors.with_opacity(0.18, ft.colors.WHITE),[m
[32m+[m[32m            border=ft.border.all(1, ft.colors.with_opacity(0.35, ft.colors.WHITE)),[m
[32m+[m[32m            content=ft.Text(descanso, size=11, weight="bold"),[m
[32m+[m[32m        )[m
[32m+[m[32m        if isinstance(cell_content, ft.Text):[m
[32m+[m[32m            if str(cell_content.value).strip().upper() in ("SN", "MD", "CMP"):[m
[32m+[m[32m                return cell_content[m
[32m+[m
[32m+[m[32m        return ft.Row([m
[32m+[m[32m            controls=[cell_content, ft.Container(width=8), tag],[m
[32m+[m[32m            spacing=0,[m
[32m+[m[32m            alignment=ft.MainAxisAlignment.START,[m
[32m+[m[32m            vertical_alignment=ft.CrossAxisAlignment.CENTER,[m
[32m+[m[32m        )[m
[32m+[m
[32m+[m[32m    def _estado_color(self, estado: str) -> str:[m
[32m+[m[32m        e = (estado or "").strip().upper()[m
[32m+[m[32m        if e == "INCOMPLETO" or e.startswith("HORAS"):[m
[32m+[m[32m            return ft.colors.RED[m
[32m+[m[32m        if e == "COMPLETO":[m
[32m+[m[32m            return ft.colors.GREEN[m
[32m+[m[32m        if e == "DUPLICADO":[m
[32m+[m[32m            return ft.colors.RED_600[m
[32m+[m[32m        if e == "PENDIENTE":[m
[32m+[m[32m            return ft.colors.GREY[m
[32m+[m[32m        return ft.colors.GREY[m
[32m+[m
[32m+[m[32m    def _update_view_controls_from_reg(self, reg: dict) -> bool:[m
[32m+[m[32m        updated = False[m
[32m+[m[32m        try:[m
[32m+[m[32m            tiempo_ctrl = reg.get("__tiempo_text")[m
[32m+[m[32m            if isinstance(tiempo_ctrl, ft.Text):[m
[32m+[m[32m                raw = reg.get("tiempo_trabajo") or reg.get("tiempo_trabajo_con_descanso") or "00:00:00"[m
[32m+[m[32m                s = str(raw or "").strip()[m
[32m+[m[32m                parts = s.split()[m
[32m+[m[32m                if len(parts) >= 2 and parts[0].upper() in ("SN", "MD", "CMP"):[m
[32m+[m[32m                    s = parts[1].strip()[m
[32m+[m[32m                tiempo_ctrl.value = s[m
[32m+[m[32m                updated = True[m
[32m+[m
[32m+[m[32m            estado_ctrl = reg.get("__estado_text")[m
[32m+[m[32m            if isinstance(estado_ctrl, ft.Text):[m
[32m+[m[32m                est = (reg.get("estado") or "PENDIENTE").strip().upper()[m
[32m+[m[32m                if estado_ctrl.value != "DUPLICADO":[m
[32m+[m[32m                    estado_ctrl.value = est[m
[32m+[m[32m                    estado_ctrl.color = self._estado_color(est)[m
[32m+[m[32m                    updated = True[m
[32m+[m
[32m+[m[32m            self._safe_update()[m
[32m+[m[32m            return updated[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return updated[m
[32m+[m
[32m+[m[32m    # --------------------- LLAVE ESTABLE / búsqueda ---------------------[m
[32m+[m[32m    def _ensure_keys(self, r: dict) -> None:[m
[32m+[m[32m        """Garantiza llaves internas estables para edición/DB."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if "__fecha_iso" not in r or not str(r.get("__fecha_iso") or "").strip():[m
[32m+[m[32m                r["__fecha_iso"] = self._fecha_to_iso(r.get("fecha"))[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            r["__fecha_iso"] = self._fecha_to_iso(r.get("fecha"))[m
[32m+[m
[32m+[m[32m    def _find_reg(self, numero: int, fecha_iso: str) -> tuple[str | None, dict | None]:[m
[32m+[m[32m        """Busca el registro por llave estable (numero, fecha_iso) en todos los grupos."""[m
[32m+[m[32m        for g, regs in self.datos_por_grupo.items():[m
[32m+[m[32m            for r in regs:[m
[32m+[m[32m                self._ensure_keys(r)[m
[32m+[m[32m                if int(r.get("numero_nomina") or 0) == int(numero) and str(r.get("__fecha_iso")) == str(fecha_iso):[m
[32m+[m[32m                    return g, r[m
[32m+[m[32m        return None, None[m
[32m+[m
[32m+[m[32m    def _get_current_edit_key(self) -> tuple[int, str] | None:[m
[32m+[m[32m        """Devuelve (numero, fecha_iso) que esté en edición (True)."""[m
[32m+[m[32m        for k, v in self.editando.items():[m
[32m+[m[32m            if v is True and isinstance(k, tuple) and len(k) == 2:[m
[32m+[m[32m                try:[m
[32m+[m[32m                    return int(k[0]), str(k[1])[m
[32m+[m[32m                except Exception:[m
[32m+[m[32m                    return None[m
[32m+[m[32m        return None[m
[32m+[m
[32m+[m[32m    # --------------------- NUEVO: Descanso editable en modo vista (autosave) ---------------------[m
[32m+[m[32m    def _make_descanso_dropdown(self, grupo: str, reg: dict) -> ft.Dropdown:[m
[32m+[m[32m        self._ensure_keys(reg)[m
[32m+[m[32m        actual = self._normalizar_descanso(reg.get("descanso"))[m
[32m+[m[32m        dd = ft.Dropdown([m
[32m+[m[32m            value=actual,[m
[32m+[m[32m            width=90,[m
[32m+[m[32m            content_padding=ft.padding.symmetric(horizontal=6, vertical=2),[m
[32m+[m[32m            text_size=12,[m
[32m+[m[32m            dense=True,[m
[32m+[m[32m            options=[ft.dropdown.Option("SN"), ft.dropdown.Option("MD"), ft.dropdown.Option("CMP")],[m
[32m+[m[32m        )[m
[32m+[m
[32m+[m[32m        def _on_change(e: ft.ControlEvent):[m
[32m+[m[32m            nuevo = self._normalizar_descanso(e.control.value)[m
[32m+[m[32m            anterior = self._normalizar_descanso(reg.get("descanso"))[m
[32m+[m[32m            if nuevo == anterior:[m
[32m+[m[32m                return[m
[32m+[m[32m            self._autosave_descanso(grupo=grupo, reg=reg, nuevo_descanso=nuevo)[m
[32m+[m
[32m+[m[32m        dd.on_change = _on_change[m
[32m+[m[32m        return dd[m
[32m+[m
[32m+[m[32m    def _autosave_descanso(self, grupo: str, reg: dict, nuevo_descanso: str) -> None:[m
[32m+[m[32m        """[m
[32m+[m[32m        Guarda descanso sin entrar a modo edición (autosave).[m
[32m+[m[32m        ✅ Guarda en DB[m
[32m+[m[32m        ✅ Re-lee el registro (ya recalculado por triggers)[m
[32m+[m[32m        ✅ Refresca UI[m
[32m+[m[32m        """[m
[32m+[m[32m        updated = False[m
[32m+[m[32m        try:[m
[32m+[m[32m            self._sync_row_helper_page()[m
[32m+[m[32m            self._ensure_keys(reg)[m
[32m+[m
[32m+[m[32m            numero = int(reg.get("numero_nomina") or 0)[m
[32m+[m[32m            if numero <= 0:[m
[32m+[m[32m                self.window_snackbar.show_error("❌ Nómina inválida. No se pudo guardar el descanso.")[m
[32m+[m[32m                return[m
[32m+[m
[32m+[m[32m            fecha_iso = str(reg.get("__fecha_iso") or "").strip()[m
[32m+[m[32m            if not fecha_iso:[m
[32m+[m[32m                fecha_iso = self._fecha_to_iso(reg.get("fecha"))[m
[32m+[m[32m            if not fecha_iso:[m
[32m+[m[32m                self.window_snackbar.show_error("❌ Fecha inválida. No se pudo guardar el descanso.")[m
[32m+[m[32m                return[m
[32m+[m
[32m+[m[32m            descanso_label = self._normalizar_descanso(nuevo_descanso)[m
[32m+[m[32m            descanso_int = self._descanso_to_int(descanso_label)[m
[32m+[m
[32m+[m[32m            # -------------------- Recalculo UI inmediato --------------------[m
[32m+[m[32m            try:[m
[32m+[m[32m                entrada_local = self.calculo_helper.sanitizar_hora(reg.get("hora_entrada", ""))[m
[32m+[m[32m                salida_local = self.calculo_helper.sanitizar_hora(reg.get("hora_salida", ""))[m
[32m+[m[32m                res_local = self.calculo_helper.recalcular_con_estado(entrada_local, salida_local, descanso_label)[m
[32m+[m[32m                reg["tiempo_trabajo"] = res_local.get("tiempo_trabajo")[m
[32m+[m[32m                reg["tiempo_trabajo_con_descanso"] = res_local.get("tiempo_trabajo_con_descanso")[m
[32m+[m[32m                estado_actual = str(reg.get("estado") or "").strip().upper()[m
[32m+[m[32m                if estado_actual != "DUPLICADO":[m
[32m+[m[32m                    reg["estado"] = "COMPLETO" if res_local.get("estado") == "ok" else "INCOMPLETO"[m
[32m+[m[32m                updated = self._update_view_controls_from_reg(reg)[m
[32m+[m[32m            except Exception:[m
[32m+[m[32m                pass[m
[32m+[m
[32m+[m[32m            # -------------------- Guardar en DB --------------------[m
[32m+[m[32m            resultado_db = None[m
[32m+[m[32m            if hasattr(self.asistencia_model, "update_descanso"):[m
[32m+[m[32m                resultado_db = self.asistencia_model.update_descanso([m
[32m+[m[32m                    numero_nomina=numero,[m
[32m+[m[32m                    fecha=fecha_iso,[m
[32m+[m[32m                    descanso=descanso_int,[m
[32m+[m[32m                )[m
[32m+[m[32m            elif hasattr(self.asistencia_model, "update_asistencia"):[m
[32m+[m[32m                resultado_db = self.asistencia_model.update_asistencia([m
[32m+[m[32m                    {"numero_nomina": numero, "fecha": fecha_iso, "descanso": descanso_int}[m
[32m+[m[32m                )[m
[32m+[m[32m            else:[m
[32m+[m[32m                self.window_snackbar.show_error("❌ El modelo no expone un método para guardar descanso.")[m
[32m+[m[32m                return[m
 [m
[32m+[m[32m            if not resultado_db or resultado_db.get("status") != "success":[m
[32m+[m[32m                msg = (resultado_db or {}).get("message", "Error al guardar descanso.")[m
[32m+[m[32m                self.window_snackbar.show_error(f"❌ {msg}")[m
[32m+[m[32m                return[m
[32m+[m
[32m+[m[32m            # -------------------- Releer registro recalculado --------------------[m
[32m+[m[32m            row_db = None[m
[32m+[m[32m            try:[m
[32m+[m[32m                row_db = self.asistencia_model.get_by_empleado_fecha(numero, fecha_iso)[m
[32m+[m[32m            except Exception:[m
[32m+[m[32m                row_db = None[m
[32m+[m
[32m+[m[32m            if isinstance(row_db, dict) and row_db:[m
[32m+[m[32m                reg["__fecha_iso"] = self._fecha_to_iso(row_db.get("fecha")) or fecha_iso[m
[32m+[m[32m                reg["fecha"] = self._fecha_to_display(row_db.get("fecha"))[m
[32m+[m[32m                reg["descanso"] = self._normalizar_descanso(row_db.get("descanso"))[m
[32m+[m[32m                reg["hora_entrada"] = self._normalizar_hora_display(row_db.get("hora_entrada"))[m
[32m+[m[32m                reg["hora_salida"] = self._normalizar_hora_display(row_db.get("hora_salida"))[m
[32m+[m[32m                if "tiempo_trabajo" in row_db:[m
[32m+[m[32m                    reg["tiempo_trabajo"] = self._decimal_horas_a_hhmm(row_db.get("tiempo_trabajo"))[m
[32m+[m[32m                if "tiempo_trabajo_con_descanso" in row_db:[m
[32m+[m[32m                    reg["tiempo_trabajo_con_descanso"] = self._decimal_horas_a_hhmm([m
[32m+[m[32m                        row_db.get("tiempo_trabajo_con_descanso")[m
[32m+[m[32m                    )[m
[32m+[m[32m                estado_db = str(row_db.get("estado") or "").strip().upper()[m
[32m+[m[32m                reg["estado"] = estado_db if estado_db else "INCOMPLETO"[m
[32m+[m[32m                updated = self._update_view_controls_from_reg(reg)[m
[32m+[m[32m            else:[m
[32m+[m[32m                reg["descanso"] = descanso_label[m
[32m+[m[32m                updated = self._update_view_controls_from_reg(reg)[m
[32m+[m
[32m+[m[32m            extra_sync = self._formatear_resumen_sync((resultado_db or {}).get("sync"))[m
[32m+[m[32m            self.window_snackbar.show_success(f"✅ Descanso actualizado a {descanso_label}.{extra_sync}")[m
[32m+[m
[32m+[m[32m            self._emit_pagamentos_delta([m
[32m+[m[32m                {"id_empleado": numero, "periodo_ini": fecha_iso, "periodo_fin": fecha_iso},[m
[32m+[m[32m                message=f"Pagos: descanso actualizado ({descanso_label}) para ID {numero}",[m
[32m+[m[32m            )[m
[32m+[m
[32m+[m[32m            # refresca sólo el grupo para asegurar UI sincronizada[m
[32m+[m[32m            self._refrescar_filas_grupo(grupo)[m
[32m+[m[32m            self._safe_update()[m
[32m+[m
[32m+[m[32m        except Exception as e:[m
[32m+[m[32m            self.window_snackbar.show_error(f"⚠️ No se pudo guardar descanso: {e}")[m
[32m+[m
[32m+[m[32m    def _commit_descanso_from_rowhelper(self, registro: dict | None = None, payload: dict | None = None, **kwargs):[m
[32m+[m[32m        """[m
[32m+[m[32m        Persiste descanso desde fila en edición sin forzar refresh de snapshot DB.[m
[32m+[m[32m        Evita pisar horas editadas aún no guardadas.[m
[32m+[m[32m        """[m
[32m+[m[32m        try:[m
[32m+[m[32m            reg = registro or payload or {}[m
[32m+[m[32m            numero = int(reg.get("numero_nomina") or 0)[m
[32m+[m[32m            if numero <= 0:[m
[32m+[m[32m                return {"status": "error", "message": "numero_nomina inválido"}[m
[32m+[m
[32m+[m[32m            fecha_iso = str(reg.get("__fecha_iso") or "").strip()[m
[32m+[m[32m            if not fecha_iso:[m
[32m+[m[32m                fecha_iso = self._fecha_to_iso(reg.get("fecha"))[m
[32m+[m[32m            if not fecha_iso:[m
[32m+[m[32m                return {"status": "error", "message": "fecha inválida"}[m
[32m+[m
[32m+[m[32m            descanso_label = self._normalizar_descanso(reg.get("descanso", "MD"))[m
[32m+[m[32m            descanso_int = self._descanso_to_int(descanso_label)[m
[32m+[m
[32m+[m[32m            if hasattr(self.asistencia_model, "update_descanso"):[m
[32m+[m[32m                return self.asistencia_model.update_descanso([m
[32m+[m[32m                    numero_nomina=numero,[m
[32m+[m[32m                    fecha=fecha_iso,[m
[32m+[m[32m                    descanso=descanso_int,[m
[32m+[m[32m                    return_row=False,[m
[32m+[m[32m                )[m
[32m+[m[32m            if hasattr(self.asistencia_model, "update_asistencia"):[m
[32m+[m[32m                return self.asistencia_model.update_asistencia([m
[32m+[m[32m                    {"numero_nomina": numero, "fecha": fecha_iso, "descanso": descanso_int}[m
[32m+[m[32m                )[m
[32m+[m[32m            return {"status": "error", "message": "No hay método para guardar descanso"}[m
