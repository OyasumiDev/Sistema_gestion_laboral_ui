[32m+[m[32m            name_cell = fila_ui.cells[1].content[m
[32m+[m[32m            if not isinstance(num_cell, ft.Container) or not isinstance(name_cell, ft.Container):[m
[32m+[m[32m                return[m
[32m+[m[32m            numero_tf = num_cell.content[m
[32m+[m[32m            nombre_txt = name_cell.content[m
[32m+[m
[32m+[m[32m            if not isinstance(numero_tf, ft.TextField) or not isinstance(nombre_txt, ft.Text):[m
[32m+[m[32m                return[m
[32m+[m
[32m+[m[32m            prev_blur = getattr(numero_tf, "on_blur", None)[m
[32m+[m
[32m+[m[32m            def _on_blur_compuesto(e):[m
[32m+[m[32m                try:[m
[32m+[m[32m                    if callable(prev_blur):[m
[32m+[m[32m                        prev_blur(e)[m
[32m+[m[32m                except Exception:[m
[32m+[m[32m                    pass[m
[32m+[m
[32m+[m[32m                try:[m
[32m+[m[32m                    val = str(numero_tf.value or "").strip()[m
[32m+[m[32m                    if val.isdigit():[m
[32m+[m[32m                        nombre = (resolver_nombre(int(val)) or "").strip()[m
[32m+[m[32m                        registro["nombre_completo"] = nombre[m
[32m+[m[32m                        nombre_txt.value = nombre if nombre else "—"[m
[32m+[m[32m                    else:[m
[32m+[m[32m                        registro["nombre_completo"] = ""[m
[32m+[m[32m                        nombre_txt.value = "—"[m
[32m+[m[32m                except Exception:[m
[32m+[m[32m                    registro["nombre_completo"] = ""[m
[32m+[m[32m                    nombre_txt.value = "—"[m
 [m
[32m+[m[32m                self._safe_update()[m
[32m+[m
[32m+[m[32m            numero_tf.on_blur = _on_blur_compuesto[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
