[32m+[m
[32m+[m[32m        self._recompute_layout_sizes()[m
[32m+[m[32m        self._update_panels_viewport_sizes()[m
[32m+[m[32m        self._safe_update()[m
[32m+[m
[32m+[m[32m    def will_unmount(self):[m
[32m+[m[32m        # restaurar on_resize previo[m
[32m+[m[32m        try:[m
[32m+[m[32m            if self.page and self._prev_on_resize is not None:[m
[32m+[m[32m                self.page.on_resize = self._prev_on_resize[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m    def _on_page_resize_chained(self, e: ft.ControlEvent | None):[m
[32m+[m[32m        try:[m
[32m+[m[32m            if callable(self._prev_on_resize):[m
[32m+[m[32m                self._prev_on_resize(e)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m[32m        self._on_page_resize(e)[m
[32m+[m
[32m+[m[32m    # --------------------- Update seguro ---------------------[m
[32m+[m[32m    def _safe_update(self, control: ft.Control | None = None):[m
[32m+[m[32m        try:[m
[32m+[m[32m            if control is not None:[m
[32m+[m[32m                control.update()[m
[32m+[m[32m                return[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m[32m        try:[m
[32m+[m[32m            if self.page:[m
[32m+[m[32m                self.page.update()[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
[32m+[m
[32m+[m[32m    def _sync_row_helper_page(self):[m
[32m+[m[32m        """✅ Mantiene el RowHelper apuntando a la page real."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if getattr(self, "row_helper", None) is None:[m
[32m+[m[32m                return[m
[32m+[m[32m            if self.page:[m
[32m+[m[32m                setattr(self.row_helper, "page", self.page)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            pass[m
