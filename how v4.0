 [m
 class CalculoHorasHelper:[m
[32m+[m[32m    """[m
[32m+[m[32m    Helper núcleo para:[m
[32m+[m[32m    - Cálculo de horas trabajadas (neto y con descanso)[m
[32m+[m[32m    - Validación segura (mientras se escribe)[m
[32m+[m[32m    - Normalización de descanso (SN/MD/CMP) + soporte int 0/1/2[m
[32m+[m[32m    - Validación de duplicados por (numero_nomina, fecha) dentro del grupo[m
[32m+[m[32m    - Helpers visuales para TextField (errores sin romper el borde OUTLINE)[m
[32m+[m
[32m+[m[32m    Reglas acordadas en el chat:[m
[32m+[m[32m    - Descanso default: MD[m
[32m+[m[32m    - Si horas incompletas: NO marcar error duro (estado = 'incompleto')[m
[32m+[m[32m    - Si salida <= entrada: estado = 'negativo'[m
[32m+[m[32m    - Permitir recalcular descanso sin entrar a edición (depende solo de entrada/salida/descanso)[m
[32m+[m[32m    """[m
[32m+[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    # Normalizaciones base[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def normalizar_descanso(v: Any) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Normaliza cualquier valor de descanso a: 'SN', 'MD', 'CMP'[m
[32m+[m[32m        Acepta:[m
[32m+[m[32m        - None, "", "NULL" -> MD[m
[32m+[m[32m        - int/str "0" -> SN ; "1" -> MD ; "2" -> CMP[m
[32m+[m[32m        - "SN/MD/CMP" (case-insensitive)[m
[32m+[m[32m        """[m
[32m+[m[32m        if v is None:[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        s = str(v).strip().upper()[m
[32m+[m[32m        if s in ("", "NONE", "NULL"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        if s in ("0", "SN", "SIN"):[m
[32m+[m[32m            return "SN"[m
[32m+[m[32m        if s in ("1", "MD", "MEDIO"):[m
[32m+[m[32m            return "MD"[m
[32m+[m[32m        if s in ("2", "CMP", "COMIDA", "COMPLETO"):[m
[32m+[m[32m            return "CMP"[m
[32m+[m[32m        return "MD" if s not in ("SN", "MD", "CMP") else s[m
[32m+[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def obtener_minutos_descanso(tipo: Any) -> int:[m
[32m+[m[32m        """[m
[32m+[m[32m        Regla del proyecto:[m
[32m+[m[32m        - SN = 0[m
[32m+[m[32m        - MD = 30 (default)[m
[32m+[m[32m        - CMP = 60[m
[32m+[m[32m        """[m
[32m+[m[32m        t = CalculoHorasHelper.normalizar_descanso(tipo)[m
[32m+[m[32m        return {"SN": 0, "MD": 30, "CMP": 60}[t][m
[32m+[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    # Parseo robusto de hora[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def _is_hora_completa(v: str) -> bool:[m
[32m+[m[32m        """[m
[32m+[m[32m        True si es HH:MM o HH:MM:SS completo. (No acepta parciales tipo "6:" o "6:2")[m
[32m+[m[32m        """[m
[32m+[m[32m        if not v:[m
[32m+[m[32m            return False[m
[32m+[m[32m        s = str(v).strip()[m
[32m+[m[32m        m = re.fullmatch(r"(\d{1,2}):(\d{2})(?::(\d{2}))?$", s)[m
[32m+[m[32m        if not m:[m
[32m+[m[32m            return False[m
[32m+[m[32m        try:[m
[32m+[m[32m            h = int(m.group(1))[m
[32m+[m[32m            mi = int(m.group(2))[m
[32m+[m[32m            se = int(m.group(3)) if m.group(3) else 0[m
[32m+[m[32m            return 0 <= h <= 23 and 0 <= mi <= 59 and 0 <= se <= 59[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return False[m
[32m+[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def entrada_completa(entrada: str, salida: str) -> bool:[m
[32m+[m[32m        """[m
[32m+[m[32m        Evita calcular mientras el usuario escribe horas parciales.[m
[32m+[m[32m        """[m
[32m+[m[32m        return CalculoHorasHelper._is_hora_completa(entrada) and CalculoHorasHelper._is_hora_completa(salida)[m
[32m+[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def parse_time(value: Any) -> Optional[time]:[m
[32m+[m[32m        """[m
[32m+[m[32m        Convierte a time.[m
[32m+[m[32m        - Acepta time/datetime/str[m
[32m+[m[32m        - Rechaza timedelta[m
[32m+[m[32m        - str: HH:MM o HH:MM:SS (completo)[m
[32m+[m[32m        """[m
[32m+[m[32m        if value is None:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        if isinstance(value, time):[m
[32m+[m[32m            return value[m
[32m+[m
[32m+[m[32m        if isinstance(value, timedelta):[m
[32m+[m[32m            # No es hora; es duración.[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        if isinstance(value, datetime):[m
[32m+[m[32m            return value.time()[m
[32m+[m
[32m+[m[32m        s = value if isinstance(value, str) else str(value)[m
[32m+[m[32m        s = s.strip()[m
[32m+[m[32m        if not s:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        # Normaliza "H:MM" -> "HH:MM"[m
[32m+[m[32m        # (pero SOLO si ya es completo, no parcial)[m
[32m+[m[32m        if not CalculoHorasHelper._is_hora_completa(s):[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        for fmt in ("%H:%M:%S", "%H:%M"):[m
[32m+[m[32m            try:[m
[32m+[m[32m                return datetime.strptime(s, fmt).time()[m
[32m+[m[32m            except ValueError:[m
[32m+[m[32m                continue[m
[32m+[m[32m        return None[m
[32m+[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def sanitizar_hora(valor: Any) -> str:[m
[32m+[m[32m        """[m
[32m+[m[32m        Devuelve string HH:MM (sin segundos en UI) si puede.[m
[32m+[m[32m        Acepta time/datetime/timedelta/str.[m
[32m+[m[32m        """[m
[32m+[m[32m        if valor is None:[m
[32m+[m[32m            return ""[m
[32m+[m
[32m+[m[32m        if isinstance(valor, time):[m
[32m+[m[32m            return valor.strftime("%H:%M")[m
[32m+[m
[32m+[m[32m        if isinstance(valor, datetime):[m
[32m+[m[32m            return valor.time().strftime("%H:%M")[m
[32m+[m
[32m+[m[32m        if isinstance(valor, timedelta):[m
[32m+[m[32m            total_seconds = int(valor.total_seconds())[m
[32m+[m[32m            h = total_seconds // 3600[m
[32m+[m[32m            m = (total_seconds % 3600) // 60[m
[32m+[m[32m            return f"{h:02}:{m:02}"[m
[32m+[m
[32m+[m[32m        s = valor if isinstance(valor, str) else str(valor)[m
[32m+[m[32m        s = s.strip()[m
[32m+[m[32m        if not s:[m
[32m+[m[32m            return ""[m
 [m
[32m+[m[32m        # Limpieza básica: "6:2" NO lo forzamos a completo, lo dejamos igual para que la validación lo trate como incompleto.[m
[32m+[m[32m        # Solo normalizamos cuando ya es "completo" (H:MM / HH:MM / HH:MM:SS)[m
[32m+[m[32m        m = re.fullmatch(r"(\d{1,2}):(\d{2})(?::(\d{2}))?$", s)[m
[32m+[m[32m        if not m:[m
[32m+[m[32m            return s  # el RowHelper puede seguir editando; aquí no rompemos input[m
[32m+[m
[32m+[m[32m        hh = int(m.group(1))[m
[32m+[m[32m        mm = int(m.group(2))[m
[32m+[m[32m        # si trae segundos, los ignoramos para UI de campos hora[m
[32m+[m[32m        if 0 <= hh <= 23 and 0 <= mm <= 59:[m
[32m+[m[32m            return f"{hh:02}:{mm:02}"[m
[32m+[m[32m        return s[m
[32m+[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    # Cálculo principal[m
[32m+[m[32m    # -------------------------[m
