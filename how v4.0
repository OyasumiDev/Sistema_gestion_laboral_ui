[32m+[m[32m    def _convertir_fecha_a_mysql(self, fecha: DateLike) -> str:[m
[32m+[m[32m        """Acepta 'DD/MM/YYYY', 'YYYY-MM-DD', datetime/date. Retorna 'YYYY-MM-DD'."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if isinstance(fecha, datetime):[m
[32m+[m[32m                return fecha.strftime("%Y-%m-%d")[m
[32m+[m[32m            if isinstance(fecha, date):[m
[32m+[m[32m                return fecha.strftime("%Y-%m-%d")[m
[32m+[m
[32m+[m[32m            s = str(fecha).strip()[m
[32m+[m[32m            if not s:[m
[32m+[m[32m                return s[m
[32m+[m
[32m+[m[32m            if "/" in s:[m
[32m+[m[32m                return datetime.strptime(s, "%d/%m/%Y").strftime("%Y-%m-%d")[m
[32m+[m[32m            return s[m
[32m+[m[32m        except Exception as e:[m
[32m+[m[32m            print(f"❌ Error formateando fecha para MySQL '{fecha}': {e}")[m
[32m+[m[32m            return str(fecha)[m
[32m+[m
[32m+[m[32m    def _formatear_fecha(self, fecha_sql: str) -> str:[m
[32m+[m[32m        """Convierte 'YYYY-MM-DD' a 'DD/MM/YYYY' si es posible."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            return datetime.strptime(str(fecha_sql), "%Y-%m-%d").strftime("%d/%m/%Y")[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return str(fecha_sql)[m
[32m+[m
[32m+[m[32m    def _mapear_descanso_str_a_int(self, descanso_str: str) -> int:[m
[32m+[m[32m        """[m
[32m+[m[32m        SN=0, MD=1, CMP=2.[m
[32m+[m[32m        ✅ Si viene vacío/NULL => MD (1).[m
[32m+[m[32m        """[m
[32m+[m[32m        s = str(descanso_str).strip().upper()[m
[32m+[m[32m        if s in ("", "NONE", "NULL"):[m
[32m+[m[32m            return 1  # default MD[m
[32m+[m[32m        if s in ("0", "SN", "SIN"):[m
[32m+[m[32m            return 0[m
[32m+[m[32m        if s in ("1", "MD", "MEDIO"):[m
[32m+[m[32m            return 1[m
[32m+[m[32m        if s in ("2", "CMP", "COMIDA", "COMPLETO"):[m
[32m+[m[32m            return 2[m
[32m+[m[32m        return 1[m
[32m+[m
[32m+[m[32m    def _mapear_descanso_a_int(self, descanso: Any) -> int:[m
[32m+[m[32m        """Acepta int(0/1/2) o string. ✅ default MD."""[m
[32m+[m[32m        try:[m
[32m+[m[32m            if descanso is None:[m
[32m+[m[32m                return 1[m
[32m+[m[32m            if isinstance(descanso, int):[m
[32m+[m[32m                return descanso if descanso in (0, 1, 2) else 1[m
[32m+[m[32m            return self._mapear_descanso_str_a_int(descanso)[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return 1[m
[32m+[m
[32m+[m[32m    def _parse_hora_nullable(self, hora: TimeLike) -> Optional[str]:[m
[32m+[m[32m        """[m
[32m+[m[32m        Normaliza hora a 'HH:MM:SS' o None.[m
[32m+[m[32m        ✅ None si viene vacío / inválido / 00:00(:00).[m
[32m+[m[32m        """[m
[32m+[m[32m        if hora is None:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m        try:[m
[32m+[m[32m            if isinstance(hora, time):[m
[32m+[m[32m                s = hora.strftime("%H:%M:%S")[m
[32m+[m[32m                return None if s in ("00:00:00", "0:00:00") else s[m
[32m+[m
[32m+[m[32m            if isinstance(hora, timedelta):[m
[32m+[m[32m                s = (datetime.min + hora).time().strftime("%H:%M:%S")[m
[32m+[m[32m                return None if s in ("00:00:00", "0:00:00") else s[m
[32m+[m
[32m+[m[32m            if isinstance(hora, str):[m
[32m+[m[32m                s = hora.strip()[m
[32m+[m[32m                if not s:[m
[32m+[m[32m                    return None[m
[32m+[m[32m                for fmt in ("%H:%M:%S", "%H:%M"):[m
[32m+[m[32m                    try:[m
[32m+[m[32m                        out = datetime.strptime(s, fmt).strftime("%H:%M:%S")[m
[32m+[m[32m                        return None if out in ("00:00:00", "0:00:00") else out[m
[32m+[m[32m                    except Exception:[m
[32m+[m[32m                        continue[m
[32m+[m[32m                return None[m
[32m+[m
[32m+[m[32m            return None[m
[32m+[m[32m        except Exception:[m
[32m+[m[32m            return None[m
[32m+[m
[32m+[m[32m    @staticmethod[m
[32m+[m[32m    def _truthy(v: Any) -> bool:[m
[32m+[m[32m        if isinstance(v, bool):[m
[32m+[m[32m            return v[m
[32m+[m[32m        if v is None:[m
[32m+[m[32m            return False[m
[32m+[m[32m        s = str(v).strip().lower()[m
[32m+[m[32m        return s in ("1", "true", "t", "yes", "y", "si", "sí", "on")[m
[32m+[m
[32m+[m[32m    def _mapear_fila_asistencia(self, row: Dict[str, Any]) -> Dict[str, Any]:[m
[32m+[m[32m        """[m
[32m+[m[32m        Normaliza para UI:[m
[32m+[m[32m        - fecha => DD/MM/YYYY[m
[32m+[m[32m        - descanso => SN/MD/CMP (✅ default MD)[m
[32m+[m[32m        - NO inventa tiempos: renderiza lo que venga de DB (triggers = verdad)[m
[32m+[m[32m        """[m
[32m+[m[32m        try:[m
[32m+[m[32m            descanso_map = {0: "SN", 1: "MD", 2: "CMP"}[m
[32m+[m
[32m+[m[32m            if "fecha" in row and row["fecha"] is not None:[m
[32m+[m[32m                row["fecha"] = self._formatear_fecha(str(row["fecha"]))[m
[32m+[m
[32m+[m[32m            raw_desc = row.get(E_ASSISTANCE.DESCANSO.value, None)[m
[32m+[m[32m            if raw_desc is None or str(raw_desc).strip() == "":[m
[32m+[m[32m                raw_desc = 1[m
[32m+[m[32m            try:[m
[32m+[m[32m                raw_desc_int = int(raw_desc)[m
[32m+[m[32m            except Exception:[m
[32m+[m[32m                raw_desc_int = 1[m
[32m+[m[32m            row["descanso"] = descanso_map.get(raw_desc_int, "MD")[m
 [m
[32m+[m[32m            # DB es la verdad: si viene null/vacío, mostramos 00:00:00 por UI[m
[32m+[m[32m            for k in (E_ASSISTANCE.TIEMPO_TRABAJO.value, E_ASSISTANCE.TIEMPO_TRABAJO_CON_DESCANSO.value):[m
[32m+[m[32m                val = row.get(k, None)[m
[32m+[m[32m                if val is None or str(val).strip() == "":[m
[32m+[m[32m                    row[k] = "00:00:00"[m
 [m
[32m+[m[32m            return row[m
[32m+[m[32m        except Exception as e:[m
[32m+[m[32m            print(f"❌ Error al mapear fila asistencia: {e}")[m
[32m+[m[32m            return row[m
[32m+[m
