[32m+[m[32m        sal_ok = self._is_hora_completa((salida_field.value or "").strip())[m
[32m+[m
[32m+[m[32m        if not ent_ok:[m
[32m+[m[32m            self._set_border_error(entrada_field, "Hora inválida. Usa HH:MM o HH:MM:SS")[m
[32m+[m[32m        else:[m
[32m+[m[32m            self._clear_border_error(entrada_field)[m
[32m+[m
[32m+[m[32m        if not sal_ok:[m
[32m+[m[32m            self._set_border_error(salida_field, "Hora inválida. Usa HH:MM o HH:MM:SS")[m
[32m+[m[32m        else:[m
