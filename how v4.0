[32m+[m[32m    # -------------------------[m
[32m+[m[32m    # Construcción de columnas[m
[32m+[m[32m    # -------------------------[m
     def build_columns(self, columnas_definidas: List[Tuple[str, str]]) -> List[ft.DataColumn]:[m
         """[m
[31m-        Crea DataColumns a partir de (titulo, clave). Si hay callbacks de edición/elim,[m
[31m-        agrega una última columna 'Acciones'.[m
[32m+[m[32m        Entrada esperada: lista de (titulo, clave).[m
[32m+[m
[32m+[m[32m        Regla de oro:[m
[32m+[m[32m        - Este builder SOLO construye columnas del orden canónico + Acciones al final.[m
[32m+[m[32m        - Si el container pasa llaves extra, se ignoran para no desfasar la tabla.[m
         """[m
[32m+[m[32m        # Normaliza input -> mapa clave_canónica -> título[m
[32m+[m[32m        input_map: dict[str, str] = {}[m
[32m+[m
[32m+[m[32m        for titulo, clave in (columnas_definidas or []):[m
[32m+[m[32m            if not clave:[m
[32m+[m[32m                continue[m
[32m+[m[32m            raw_key = str(clave).strip()[m
[32m+[m[32m            key = self._normalize_key(raw_key)[m
[32m+[m
[32m+[m[32m            # Si es acciones (o alias), se ignora: Acciones se agrega al final siempre[m
[32m+[m[32m            if key == "__acciones__":[m
[32m+[m[32m                continue[m
[32m+[m
[32m+[m[32m            # Si cae vacío, ignora[m
[32m+[m[32m            if not key:[m
[32m+[m[32m                continue[m
[32m+[m
[32m+[m[32m            title = str(titulo).strip() if titulo else ""[m
[32m+[m[32m            if title:[m
[32m+[m[32m                input_map[key] = title[m
[32m+[m
         cols: List[ft.DataColumn] = [][m
 [m
[31m-        for titulo, _clave in columnas_definidas:[m
[31m-            # El contenedor luego reemplaza el label por uno "clickable" si es sortable[m
[31m-            cols.append([m
[31m-                ft.DataColumn([m
[31m-                    label=ft.Text(titulo, size=12, weight="bold")[m
[31m-                )[m
[31m-            )[m
[32m+[m[32m        # 1) Columnas canónicas[m
[32m+[m[32m        for default_title, key in self._CANON:[m
[32m+[m[32m            title = input_map.get(key, default_title)[m
[32m+[m[32m            cols.append(self._col(title))[m
 [m
[31m-        if self.on_edit or self.on_delete:[m
[31m-            cols.append(ft.DataColumn(label=ft.Text("Acciones", size=12, weight="bold")))[m
[32m+[m[32m        # 2) Acciones SIEMPRE al final[m
[32m+[m[32m        if self.force_actions_column or self.on_edit or self.on_delete:[m
[32m+[m[32m            cols.append(self._actions_col())[m
 [m
         return cols[m
 [m
[31m-    # Opcional: útil si en algún punto quieres que el builder te fabrique los botones de acción.[m
[31m-    # El contenedor/row helper ya gestionan esto, pero lo dejamos disponible por compatibilidad.[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    # Helpers internos[m
[32m+[m[32m    # -------------------------[m
[32m+[m[32m    def _normalize_key(self, key: str) -> str:[m
[32m+[m[32m        k = (key or "").strip()[m
[32m+[m[32m        if not k:[m
[32m+[m[32m            return ""[m
[32m+[m[32m        k = self._ALIASES.get(k, k)[m
[32m+[m[32m        return k[m
[32m+[m
[32m+[m[32m    def _col(self, title: str) -> ft.DataColumn:[m
[32m+[m[32m        return ft.DataColumn([m
[32m+[m[32m            label=ft.Text(title, size=12, weight=ft.FontWeight.BOLD, no_wrap=True)[m
[32m+[m[32m        )[m
[32m+[m
